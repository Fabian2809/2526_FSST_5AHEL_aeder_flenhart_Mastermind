<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="720" maxWidth="460" minHeight="720" minWidth="460" prefHeight="720" prefWidth="460" style="-fx-background-color: #0d0d12;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.mastermind.Controller">

    <!-- ═══ TOP: HEADER ═══ -->
    <top>
        <VBox alignment="CENTER" spacing="3" style="-fx-background-color: #0d0d12; -fx-padding: 18 0 10 0;">
            <Label style="-fx-text-fill: #e8e8f0; -fx-font-size: 22px;                           -fx-font-weight: bold; -fx-font-family: 'Courier New';" text="MASTERMIND" />
            <Label fx:id="attemptsLabel" style="-fx-text-fill: #383848; -fx-font-size: 11px;                           -fx-font-family: 'Courier New';" text="10 Versuche verbleibend" />
        </VBox>
    </top>

    <!-- ═══ CENTER: BOARD + EINGABE ═══ -->
    <center>
        <VBox spacing="0">

            <!-- SPIELBRETT: 10 feste Zeilen -->
            <VBox fx:id="boardBox" alignment="TOP_CENTER" prefHeight="380" spacing="2" style="-fx-background-color: #0d0d12; -fx-padding: 4 24 4 24;" />

            <!-- TRENNLINIE -->
            <Separator style="-fx-background-color: #18182a; -fx-opacity: 1;" />

            <!-- EINGABE-BEREICH -->
            <VBox alignment="CENTER" spacing="9" style="-fx-background-color: #0f0f18; -fx-padding: 12 20 12 20;">

                <Label style="-fx-text-fill: #282838; -fx-font-size: 9px;                               -fx-font-family: 'Courier New';" text="AKTUELLER VERSUCH" />
            <Label fx:id="UhrzeitLabel" alignment="CENTER" prefHeight="29.0" prefWidth="47.0" text="Label" textAlignment="RIGHT" textFill="#f0eded" />

                <!-- 4 Slots -->
                <HBox fx:id="slotsBox" alignment="CENTER" spacing="10" />

                <!-- Farbpalette -->
                <HBox fx:id="colorPalette" alignment="CENTER" spacing="9" style="-fx-padding: 2 0 0 0;" />

                <!-- Fehlermeldung -->
                <Label fx:id="errorLabel" prefHeight="14" style="-fx-text-fill: #e06c75; -fx-font-size: 11px;                               -fx-font-family: 'Courier New';" text="" />

                <!-- Aktions-Buttons -->
                <HBox alignment="CENTER" spacing="9">
                    <Button fx:id="submitButton" onAction="#onGuessSubmit" prefHeight="34" prefWidth="120" style="-fx-background-color: #4a9eff; -fx-text-fill: #ffffff;                                    -fx-font-weight: bold; -fx-font-family: 'Courier New';                                    -fx-font-size: 12px; -fx-background-radius: 6;                                    -fx-cursor: hand;" text="RATEN" />
                    <Button fx:id="hintButton" onAction="#onHint" prefHeight="34" prefWidth="95" style="-fx-background-color: #1e1e2e; -fx-text-fill: #f9e2af;                                    -fx-font-family: 'Courier New'; -fx-font-size: 12px;                                    -fx-background-radius: 6; -fx-cursor: hand;                                    -fx-border-color: #2e2e40; -fx-border-radius: 6;                                    -fx-border-width: 1;" text="💡 HINT" />
                    <Button fx:id="clearButton" onAction="#onClearSlots" prefHeight="34" prefWidth="40" style="-fx-background-color: #16161f; -fx-text-fill: #444455;                                    -fx-font-size: 14px; -fx-background-radius: 6;                                    -fx-cursor: hand; -fx-border-color: #222230;                                    -fx-border-radius: 6; -fx-border-width: 1;" text="✕" />
                </HBox>

                <!-- Tastatur-Hinweis -->
                <Label style="-fx-text-fill: #1e1e2c; -fx-font-size: 9px;                               -fx-font-family: 'Courier New';" text="R G B Y O P  ·  Backspace = löschen  ·  Enter = raten" />
            </VBox>

        </VBox>
    </center>

    <!-- ═══ BOTTOM: ERGEBNIS-BANNER ═══ -->
    <bottom>
        <VBox fx:id="resultBox" alignment="CENTER" managed="false" spacing="9" style="-fx-background-color: #0c0c14;                      -fx-border-color: #1a1a26; -fx-border-width: 1 0 0 0;                      -fx-padding: 12 20 16 20;" visible="false">
            <Label fx:id="resultLabel" style="-fx-text-fill: #f9e2af; -fx-font-size: 13px;                           -fx-font-weight: bold; -fx-font-family: 'Courier New';                           -fx-text-alignment: center;" text="" wrapText="true" />
            <Button fx:id="restartButton" onAction="#onRestart" prefHeight="34" prefWidth="150" style="-fx-background-color: #a6e3a1; -fx-text-fill: #0d0d12;                            -fx-font-weight: bold; -fx-font-family: 'Courier New';                            -fx-font-size: 12px; -fx-background-radius: 6;                            -fx-cursor: hand;" text="⟳  NEUES SPIEL" />
        </VBox>
    </bottom>

</BorderPane>
