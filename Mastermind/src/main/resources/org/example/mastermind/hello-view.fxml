<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.mastermind.Controller"
      spacing="0"
      style="-fx-background-color: #0f0f13;">

    <!-- ═══ HEADER ═══ -->
    <VBox alignment="CENTER" spacing="4"
          style="-fx-background-color: #0f0f13; -fx-padding: 24 0 16 0;">
        <Label text="MASTERMIND"
               style="-fx-text-fill: #ffffff; -fx-font-size: 26px;
                      -fx-font-weight: bold; -fx-font-family: 'Courier New';
                      -fx-letter-spacing: 6px;"/>
        <Label fx:id="attemptsLabel" text="10 Versuche verbleibend"
               style="-fx-text-fill: #555566; -fx-font-size: 12px;
                      -fx-font-family: 'Courier New';"/>
    </VBox>

    <!-- ═══ SPIELBRETT ═══ -->
    <ScrollPane fx:id="scrollPane"
                fitToWidth="true" fitToHeight="false"
                prefHeight="320"
                hbarPolicy="NEVER"
                style="-fx-background: transparent;
                       -fx-background-color: transparent;
                       -fx-border-width: 0;">
        <VBox fx:id="boardBox" spacing="8" alignment="CENTER">
            <padding><Insets top="8" right="24" bottom="8" left="24"/></padding>
        </VBox>
    </ScrollPane>

    <!-- ═══ TRENNLINIE ═══ -->
    <Separator style="-fx-background-color: #222233; -fx-border-color: #222233;"/>

    <!-- ═══ AKTUELLER VERSUCH – Slots ═══ -->
    <VBox alignment="CENTER" spacing="12"
          style="-fx-background-color: #13131a; -fx-padding: 16 24 16 24;">

        <Label text="DEIN VERSUCH"
               style="-fx-text-fill: #444455; -fx-font-size: 10px;
                      -fx-font-family: 'Courier New'; -fx-letter-spacing: 3px;"/>

        <!-- 4 Slots -->
        <HBox fx:id="slotsBox" spacing="12" alignment="CENTER"/>

        <!-- Fehlermeldung -->
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #ff6b6b; -fx-font-size: 11px;
                      -fx-font-family: 'Courier New';"/>
    </VBox>

    <!-- ═══ FARBPALETTE ═══ -->
    <VBox alignment="CENTER" spacing="10"
          style="-fx-background-color: #0f0f13; -fx-padding: 16 24 16 24;">

        <Label text="FARBE WÄHLEN"
               style="-fx-text-fill: #444455; -fx-font-size: 10px;
                      -fx-font-family: 'Courier New'; -fx-letter-spacing: 3px;"/>

        <HBox fx:id="colorPalette" spacing="14" alignment="CENTER"/>
    </VBox>

    <!-- ═══ AKTIONS-BUTTONS ═══ -->
    <HBox alignment="CENTER" spacing="12"
          style="-fx-background-color: #0f0f13; -fx-padding: 0 24 20 24;">
        <Button fx:id="submitButton" text="RATEN"
                onAction="#onGuessSubmit"
                prefWidth="160" prefHeight="40"
                style="-fx-background-color: #4a9eff; -fx-text-fill: #ffffff;
                       -fx-font-weight: bold; -fx-font-family: 'Courier New';
                       -fx-font-size: 13px; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
        <Button fx:id="clearButton" text="✕  LÖSCHEN"
                onAction="#onClearSlots"
                prefWidth="120" prefHeight="40"
                style="-fx-background-color: #1a1a26; -fx-text-fill: #555566;
                       -fx-font-family: 'Courier New'; -fx-font-size: 12px;
                       -fx-background-radius: 6; -fx-cursor: hand;
                       -fx-border-color: #2a2a3e; -fx-border-radius: 6;"/>
    </HBox>

    <!-- ═══ ERGEBNIS-MELDUNG ═══ -->
    <VBox fx:id="resultBox" alignment="CENTER" spacing="14"
          style="-fx-background-color: #0f0f13; -fx-padding: 0 24 24 24;"
          visible="false" managed="false">
        <Label fx:id="resultLabel" text=""
               style="-fx-text-fill: #f9e2af; -fx-font-size: 16px;
                      -fx-font-weight: bold; -fx-font-family: 'Courier New';
                      -fx-text-alignment: center;" wrapText="true"/>
        <Button fx:id="restartButton" text="⟳  NEUES SPIEL"
                onAction="#onRestart"
                prefWidth="180" prefHeight="40"
                style="-fx-background-color: #a6e3a1; -fx-text-fill: #0f0f13;
                       -fx-font-weight: bold; -fx-font-family: 'Courier New';
                       -fx-font-size: 13px; -fx-background-radius: 6;
                       -fx-cursor: hand;"/>
    </VBox>

</VBox>
